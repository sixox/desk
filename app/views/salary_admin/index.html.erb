<!-- app/views/salary_admin/index.html.erb -->

<% unless current_user.is_manager %>
  <div class="container py-5">
    <div class="col-12 col-lg-7 mx-auto">
      <div class="alert alert-danger shadow-sm rounded-4 mb-0">
        <div class="d-flex align-items-center gap-2">
          <span class="fs-4">⛔</span>
          <div>
            <div class="fw-bold">دسترسی ندارید</div>
            <div class="small opacity-75">این صفحه فقط برای کاربرانِ مدیر (is_manager) قابل مشاهده است.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% return %>
<% end %>

<style>
  /* Only for this page */
  .sa-wrap { max-width: 1100px; margin: 0 auto; }
  .sa-hero {
    border-radius: 22px;
    border: 1px solid rgba(0,0,0,.06);
    background: radial-gradient(1200px 380px at 10% 0%, rgba(13,110,253,.10), transparent 60%),
                radial-gradient(900px 340px at 90% 10%, rgba(32,201,151,.10), transparent 55%),
                linear-gradient(180deg, rgba(0,0,0,.02), rgba(0,0,0,0));
    box-shadow: 0 14px 40px rgba(0,0,0,.06);
    overflow: hidden;
  }
  .sa-hero .sa-title { letter-spacing: -.2px; }
  .sa-muted { color: #6c757d; }

  .sa-card {
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 10px 26px rgba(0,0,0,.05);
    overflow: hidden;
    background: #fff;
  }
  .sa-card-hd {
    background: linear-gradient(180deg, rgba(0,0,0,.03), rgba(0,0,0,0));
    border-bottom: 1px solid rgba(0,0,0,.06);
    padding: 14px 16px;
  }
  .sa-card-bd { padding: 14px 16px; }

  .sa-badge {
    display: inline-flex; align-items:center; gap: 8px;
    border: 1px solid rgba(0,0,0,.08);
    background: #fff;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: .82rem;
    color: #343a40;
  }

  .sa-action {
    display:flex; align-items:center; justify-content:space-between; gap: 12px;
    padding: 12px 12px;
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px;
    background: #fff;
    text-decoration: none;
    transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease;
    color: inherit;
  }
  .sa-action:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 24px rgba(0,0,0,.07);
    border-color: rgba(13,110,253,.35);
    text-decoration: none;
  }
  .sa-action .sa-ic {
    width: 38px; height: 38px;
    border-radius: 14px;
    display:flex; align-items:center; justify-content:center;
    background: linear-gradient(180deg, rgba(13,110,253,.10), rgba(13,110,253,.03));
    border: 1px solid rgba(13,110,253,.12);
    font-size: 18px;
    flex: 0 0 auto;
  }
  .sa-action .sa-name { font-weight: 800; letter-spacing: -.2px; }
  .sa-action .sa-desc { font-size: .84rem; color: #6c757d; margin-top: 2px; }

  .sa-chip {
    font-size: .75rem;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.02);
    color: #495057;
    white-space: nowrap;
  }

  .sa-divider {
    height: 1px;
    background: rgba(0,0,0,.06);
    margin: 14px 0;
  }

  .sa-grid { display:grid; gap: 12px; }
  @media (min-width: 992px) {
    .sa-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<div class="container py-5 text-end" dir="rtl">
  <div class="sa-wrap">

    <!-- Hero -->
    <div class="sa-hero p-4 p-lg-5 mb-4">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
        <div>
          <h2 class="mb-1 sa-title fw-bold">مدیریت حقوق و دستمزد</h2>
          <div class="sa-muted">
            این داشبورد فقط برای کاربران <strong>Manager</strong> نمایش داده می‌شود.
            هر بخش براساس نقش شما (Admin / HR / Accounting / Board / CEO / …) فعال یا مخفی می‌شود.
          </div>

          <div class="mt-3 d-flex flex-wrap gap-2">
            <% if @latest_month.present? %>
              <span class="sa-badge">🗓 ماه فعال: <strong><%= @latest_month.name %></strong></span>
            <% else %>
              <span class="sa-badge">⚠️ ماه فعال: <strong>تعریف نشده</strong></span>
            <% end %>

            <span class="sa-badge">👤 نقش: <strong><%= current_user.role %></strong></span>
            <span class="sa-badge">🧩 دسترسی مدیر: <strong><%= current_user.is_manager ? "فعال" : "غیرفعال" %></strong></span>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <% if current_user.admin? %>
            <%= link_to new_shamsi_month_path, class: "btn btn-primary rounded-pill px-3" do %>
              ➕ ایجاد ماه شمسی
            <% end %>
          <% end %>

          <a class="btn btn-outline-secondary rounded-pill px-3" href="javascript:window.location.reload()">
            تازه‌سازی
          </a>
        </div>
      </div>
    </div>

    <!-- If no month -->
    <% unless @latest_month.present? %>
      <div class="sa-card">
        <div class="sa-card-hd">
          <div class="fw-bold">شروع کار</div>
          <div class="small sa-muted">برای ادامه باید ماه شمسی جدید بسازید.</div>
        </div>
        <div class="sa-card-bd">
          <% if current_user.admin? %>
            <%= link_to "➕ ایجاد ماه شمسی جدید", new_shamsi_month_path, class: "btn btn-primary rounded-pill px-4" %>
          <% else %>
            <div class="alert alert-warning rounded-4 mb-0">
              شما دسترسی ساخت ماه جدید ندارید. از ادمین بخواهید ماه جدید را بسازد.
            </div>
          <% end %>
        </div>
      </div>

      <div class="sa-divider"></div>

      <% if current_user.admin? || (current_user.accounting? && current_user.is_manager) %>
        <%= link_to "ویرایش پروفایل حقوق (گروهی)", bulk_edit_salary_profiles_path, class: "btn btn-outline-primary btn-sm rounded-pill" %>
      <% end %>

      <% return %>
    <% end %>

    <!-- Sections -->
    <div class="sa-grid">

      <!-- Month setup (Admin only) -->
<div class="sa-card">
  <div class="sa-card-hd">
    <div class="fw-bold">تنظیمات ماه</div>
    <div class="small sa-muted">تعریف تعطیلات و تنظیمات عمومی ماه جاری.</div>
  </div>

  <div class="sa-card-bd d-grid gap-2">
    <% if current_user.admin? %>

      <%= link_to edit_day_offs_shamsi_month_path(@latest_month), class: "sa-action" do %>
        <div class="d-flex align-items-center gap-3">
          <div class="sa-ic">🗓</div>
          <div>
            <div class="sa-name">تعطیلات ماه «<%= @latest_month.name %>»</div>
            <div class="sa-desc">روزهای تعطیل و جمعه‌ها برای محاسبه کسری/کارکرد اثر دارند.</div>
          </div>
        </div>
        <span class="sa-chip">Admin</span>
      <% end %>

      <!-- 🔥 NEW LINK -->
      <%= link_to rebuild_last_month_salary_archives_path,
            data: { turbo_method: :post, turbo_confirm: "آرشیو ماه «#{@latest_month.name}» کامل حذف و دوباره ساخته شود؟" },
            class: "sa-action" do %>

        <div class="d-flex align-items-center gap-3">
          <div class="sa-ic">♻️</div>
          <div>
            <div class="sa-name">Rebuild آرشیو ماه «<%= @latest_month.name %>»</div>
            <div class="sa-desc">
              آرشیو حقوق این ماه حذف می‌شود و دوباره از ابتدا ساخته خواهد شد.
            </div>
          </div>
        </div>

        <span class="sa-chip bg-warning text-dark">Danger</span>
      <% end %>

    <% else %>
      <div class="alert alert-light border rounded-4 mb-0">
        <div class="fw-semibold">این بخش فقط برای Admin فعال است.</div>
        <div class="small sa-muted">در صورت نیاز، از ادمین بخواهید تعطیلات را تنظیم کند.</div>
      </div>
    <% end %>
  </div>
</div>

      <!-- Reviews -->
      <div class="sa-card">
        <div class="sa-card-hd">
          <div class="fw-bold">بررسی‌ها و تاییدها</div>
          <div class="small sa-muted">ورود به صفحات بررسی مدیر، HR و حسابداری برای ماه جاری.</div>
        </div>

        <div class="sa-card-bd d-grid gap-2">

          <!-- Manager review (Any manager) -->
          <%= link_to manager_review_salary_archives_path(month_id: @latest_month.id), class: "sa-action" do %>
            <div class="d-flex align-items-center gap-3">
              <div class="sa-ic">🧑‍💼</div>
              <div>
                <div class="sa-name">Manager Review</div>
                <div class="sa-desc">بررسی ساعات/مرخصی/دورکاری/اضافه‌کاری زیرمجموعه‌ها و ثبت تایید مدیر.</div>
              </div>
            </div>
            <span class="sa-chip">Manager</span>
          <% end %>

          <!-- HR review (your authorize_hr_review! logic) -->
          <% if current_user.hr? || current_user.admin? || current_user.board? || current_user.ceo? || current_user.procurement? || current_user.cob? || current_user.accounting? || current_user.id == 17 %>
            <%= link_to hr_review_salary_archives_path(month_id: @latest_month.id), class: "sa-action" do %>
              <div class="d-flex align-items-center gap-3">
                <div class="sa-ic">👥</div>
                <div>
                  <div class="sa-name">All users payroll (HR Review)</div>
                  <div class="sa-desc">نمای کلی آرشیو همه کاربران برای ماه جاری (مشاهده/کنترل قبل از حسابداری).</div>
                </div>
              </div>
              <span class="sa-chip">HR/Board/…</span>
            <% end %>
          <% else %>
            <div class="alert alert-light border rounded-4 mb-0">
              <div class="fw-semibold">HR Review برای نقش شما فعال نیست.</div>
              <div class="small sa-muted">طبق authorize_hr_review فقط نقش‌های مشخص دسترسی دارند.</div>
            </div>
          <% end %>

          <!-- Accounting review -->
          <% if current_user.accounting? || current_user.admin? %>
            <%= link_to accounting_review_salary_archives_path(month_id: @latest_month.id), class: "sa-action" do %>
              <div class="d-flex align-items-center gap-3">
                <div class="sa-ic">🧾</div>
                <div>
                  <div class="sa-name">Accounting Review</div>
                  <div class="sa-desc">تایید حسابداری و ذخیره محاسبات داخل آرشیو (پایه/سنوات/بیمه/…)</div>
                </div>
              </div>
              <span class="sa-chip">Accounting/Admin</span>
            <% end %>
          <% else %>
            <div class="alert alert-light border rounded-4 mb-0">
              <div class="fw-semibold">Accounting Review برای نقش شما فعال نیست.</div>
              <div class="small sa-muted">فقط Accounting Manager یا Admin اجازه دارند.</div>
            </div>
          <% end %>

        </div>
      </div>

      <!-- Payslips -->
      <div class="sa-card">
        <div class="sa-card-hd">
          <div class="fw-bold">فیش حقوقی</div>
          <div class="small sa-muted">نمایش فیش‌های همین ماه (بعد از تایید حسابداری معنی‌دارتر است).</div>
        </div>

        <div class="sa-card-bd d-grid gap-2">
          <% if current_user.hr? || current_user.admin? || current_user.board? || current_user.ceo? || current_user.procurement? || current_user.cob? || current_user.accounting? || current_user.id == 17 %>
            <%= link_to payslips_salary_archives_path(month_id: @latest_month.id), class: "sa-action" do %>
              <div class="d-flex align-items-center gap-3">
                <div class="sa-ic">💳</div>
                <div>
                  <div class="sa-name">فیش حقوقی ماه «<%= @latest_month.name %>»</div>
                  <div class="sa-desc">فیش‌ها از داده‌های SalaryArchive تولید می‌شوند؛ اگر accounting_confirmed باشد.</div>
                </div>
              </div>
              <span class="sa-chip">HR/Board/…</span>
            <% end %>
          <% else %>
            <div class="alert alert-light border rounded-4 mb-0">
              <div class="fw-semibold">دسترسی فیش حقوقی برای نقش شما فعال نیست.</div>
              <div class="small sa-muted">طبق شرط‌های صفحه فقط نقش‌های مشخص دسترسی دارند.</div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Salary profile bulk edit -->
      <div class="sa-card">
        <div class="sa-card-hd">
          <div class="fw-bold">پروفایل حقوق</div>
          <div class="small sa-muted">ویرایش گروهی پروفایل حقوق کاربران (اعداد مبنا).</div>
        </div>

        <div class="sa-card-bd d-grid gap-2">
          <% if current_user.admin? || (current_user.accounting? && current_user.is_manager) %>
            <%= link_to bulk_edit_salary_profiles_path, class: "sa-action" do %>
              <div class="d-flex align-items-center gap-3">
                <div class="sa-ic">🛠️</div>
                <div>
                  <div class="sa-name">ویرایش پروفایل حقوق (گروهی)</div>
                  <div class="sa-desc">total_salary / hourly_rate / مزایا / ذخایر / وام و…</div>
                </div>
              </div>
              <span class="sa-chip">Admin/Accounting</span>
            <% end %>
          <% else %>
            <div class="alert alert-light border rounded-4 mb-0">
              <div class="fw-semibold">این بخش فقط برای Admin یا Accounting Manager فعال است.</div>
              <div class="small sa-muted">برای تغییر مبالغ مبنا، باید دسترسی داشته باشید.</div>
            </div>
          <% end %>
        </div>
      </div>

    </div>

    <div class="mt-4 small sa-muted">
      <strong>راهنما:</strong>
      ترتیب معمول کار: <span class="sa-chip">تعطیلات</span> → <span class="sa-chip">Manager Review</span> → <span class="sa-chip">HR Review</span> → <span class="sa-chip">Accounting Review</span> → <span class="sa-chip">فیش حقوقی</span>
    </div>

  </div>
</div>