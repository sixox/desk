<!-- app/views/salary_profiles/bulk_edit.html.erb -->
<style>
  /* ============== Page-only Pro UI (Bootstrap-friendly) ============== */
  .sp-wrap { max-width: 1500px; margin: 0 auto; }
  .sp-hero{
    border-radius: 22px;
    border: 1px solid rgba(0,0,0,.06);
    background:
      radial-gradient(1200px 380px at 10% 0%, rgba(13,110,253,.10), transparent 60%),
      radial-gradient(900px 340px at 90% 10%, rgba(32,201,151,.10), transparent 55%),
      linear-gradient(180deg, rgba(0,0,0,.02), rgba(0,0,0,0));
    box-shadow: 0 14px 40px rgba(0,0,0,.06);
    overflow: hidden;
  }
  .sp-muted { color:#6c757d; }

  .sp-pill{
    display:inline-flex; align-items:center; gap:8px;
    padding: 7px 12px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(255,255,255,.9);
    font-size: .82rem;
    color:#343a40;
    white-space: nowrap;
  }

  .sp-accordion .accordion-item{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px !important;
    overflow:hidden;
    background:#fff;
    box-shadow: 0 10px 22px rgba(0,0,0,.04);
    margin-bottom: 10px;
  }
  .sp-accordion .accordion-button{
    background: linear-gradient(180deg, rgba(0,0,0,.03), rgba(0,0,0,0));
    border:0;
    box-shadow:none !important;
  }
  .sp-accordion .accordion-button:focus{ box-shadow:none !important; }
  .sp-accordion .accordion-body{ background:#fff; }

  .sp-userline .sp-name{ font-weight: 900; letter-spacing:-.2px; }
  .sp-userline .badge{ border-radius: 999px; }

  .sp-mini-badge{
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.02);
    color:#495057;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: .78rem;
  }

  .sp-kpi{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px;
    padding: 10px 12px;
    background:#fff;
  }
  .sp-kpi .lbl{ font-size:.78rem; color:#6c757d; }
  .sp-kpi .val{ font-size:1.05rem; font-weight:800; letter-spacing:-.2px; }

  .sp-form-card{
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 10px 22px rgba(0,0,0,.04);
    overflow:hidden;
  }
  .sp-form-card .card-header{
    background: linear-gradient(180deg, rgba(0,0,0,.03), rgba(0,0,0,0));
    border-bottom: 1px solid rgba(0,0,0,.06);
  }
  .sp-section-title{ font-weight:900; letter-spacing:-.2px; font-size:.95rem; }
  .sp-section-sub{ font-size:.82rem; color:#6c757d; }

  .sp-table{
    border-radius: 18px;
    overflow:hidden;
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 10px 22px rgba(0,0,0,.04);
  }
  .sp-table thead th{ background: rgba(0,0,0,.03) !important; }

  .sp-sticky-save{ position: sticky; bottom: 12px; z-index: 3; }
  .sp-savebar{
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.06);
    background: rgba(255,255,255,.92);
    box-shadow: 0 14px 30px rgba(0,0,0,.08);
    backdrop-filter: blur(8px);
    padding: 10px 12px;
  }

  /* nicer inputs */
  .form-control, .form-select, .input-group-text{ border-radius: 12px; }
  .input-group .form-control{ border-top-right-radius:0; border-bottom-right-radius:0; }
  .input-group .input-group-text{ border-top-left-radius:0; border-bottom-left-radius:0; }
</style>

<div class="container-fluid py-4 text-end" dir="rtl">
  <div class="sp-wrap">

    <!-- Hero -->
    <div class="sp-hero p-4 p-lg-5 mb-4">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
        <div>
          <h4 class="mb-1 fw-bold">ویرایش گروهی پروفایل حقوق</h4>
          <div class="sp-muted small">
            فقط کاربران دارای <strong>SalaryProfile</strong> نمایش داده می‌شوند.
            تغییرات این صفحه روی «مبنای حقوق» ذخیره می‌شود (SalaryProfile).
          </div>

          <div class="mt-3 d-flex flex-wrap gap-2">
            <span class="sp-pill">🧾 تعداد کاربران: <strong><%= @users.size %></strong></span>
            <span class="sp-pill">🛠️ نقش شما: <strong><%= current_user.role %></strong></span>
            <span class="sp-pill">👤 مدیر: <strong><%= current_user.is_manager ? "بله" : "خیر" %></strong></span>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <%= link_to "بازگشت", :back, class: "btn btn-outline-secondary rounded-pill px-3" rescue nil %>
          <a class="btn btn-outline-dark rounded-pill px-3" href="javascript:window.location.reload()">تازه‌سازی</a>
        </div>
      </div>
    </div>

    <%= form_with url: bulk_update_salary_profiles_path, method: :patch do %>

      <!-- Top Save -->
      <div class="d-flex flex-wrap gap-2 justify-content-end mb-3">
        <%= submit_tag "ذخیره تغییرات", class: "btn btn-primary rounded-pill px-4" %>
      </div>

      <div class="accordion sp-accordion" id="salaryProfilesAcc">

        <% @users.each do |user| %>
          <% sp = user.salary_profile %>
          <% next unless sp %>

          <% pay_label =
              {
                "hourly" => "ساعتی (محاسبه کامل)",
                "fixed" => "ثابت",
                "fixed_with_overtime" => "ثابت + اضافه/کسری"
              }[sp.pay_type.to_s] || "نامشخص"
          %>

          <% total_salary = sp.total_salary.to_i %>

          <div class="accordion-item">
            <h2 class="accordion-header" id="hdr_<%= user.id %>">
              <button class="accordion-button collapsed py-3" type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#col_<%= user.id %>"
                      aria-expanded="false"
                      aria-controls="col_<%= user.id %>">

                <div class="d-flex w-100 align-items-center justify-content-between gap-3">
                  <div class="d-flex flex-column sp-userline">

                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <span class="sp-name"><%= user.name.presence || "کاربر ##{user.id}" %></span>
                      <span class="badge text-bg-light border">ID: <%= user.id %></span>
                      <span class="badge text-bg-primary"><%= pay_label %></span>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-2">
                      <span class="sp-mini-badge">حقوق کل: <strong><%= number_with_delimiter(total_salary) %></strong></span>
                      <span class="sp-mini-badge">نرخ ساعتی: <strong><%= sp.hourly_rate.present? ? number_with_delimiter(sp.hourly_rate) : "—" %></strong></span>
                      <span class="sp-mini-badge">پایه: <strong><%= number_with_delimiter(sp.seniority_base.to_i) %></strong></span>
                      <span class="sp-mini-badge">سنوات: <strong><%= number_with_delimiter(sp.monthly_seniority_base.to_i) %></strong></span>
                    </div>

                  </div>

                  <div class="d-none d-md-block">
                    <span class="badge text-bg-secondary">برای ویرایش باز کنید</span>
                  </div>
                </div>

              </button>
            </h2>

            <div id="col_<%= user.id %>" class="accordion-collapse collapse"
                 aria-labelledby="hdr_<%= user.id %>"
                 data-bs-parent="#salaryProfilesAcc">

              <div class="accordion-body p-3 p-lg-4">

                <!-- KPIs -->
                <div class="row g-2 mb-3">
                  <div class="col-12 col-md-4">
                    <div class="sp-kpi">
                      <div class="lbl">حقوق کل</div>
                      <div class="val"><%= number_with_delimiter(sp.total_salary.to_i) %></div>
                    </div>
                  </div>
                  <div class="col-12 col-md-4">
                    <div class="sp-kpi">
                      <div class="lbl">نرخ ساعتی</div>
                      <div class="val"><%= sp.hourly_rate.present? ? number_with_delimiter(sp.hourly_rate) : "—" %></div>
                    </div>
                  </div>
                  <div class="col-12 col-md-4">
                    <div class="sp-kpi">
                      <div class="lbl">جمع مزایا (مسکن + بن + تاهل + فرزند)</div>
                      <div class="val">
                        <%= number_with_delimiter(
                              sp.housing_allowance.to_i + sp.food_allowance.to_i + sp.marriage_allowance.to_i + sp.child_allowance.to_i
                            ) %>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="card sp-form-card">
                  <div class="card-header p-3">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                      <div>
                        <div class="sp-section-title">تنظیمات پروفایل حقوق</div>
                        <div class="sp-section-sub">
                          این مقادیر «مبنای آرشیو ماه» هستند. (فیش از SalaryArchive می‌خونه؛
                          اعداد آرشیو در مرحله accounting_confirm ذخیره میشن.)
                        </div>
                      </div>
                      <span class="sp-pill">🧩 SalaryProfile ID: <strong><%= sp.id %></strong></span>
                    </div>
                  </div>

                  <div class="card-body p-3 p-lg-4">
                    <div class="row g-3">

                      <!-- Pay type -->
                      <div class="col-12 col-lg-4">
                        <label class="form-label small mb-1">نوع پرداخت</label>
                        <%= select_tag "salary_profiles[#{sp.id}][pay_type]",
                              options_for_select(
                                [
                                  ["ساعتی (محاسبه کامل)", "hourly"],
                                  ["ثابت", "fixed"],
                                  ["ثابت + اضافه/کسری", "fixed_with_overtime"]
                                ],
                                sp.pay_type.to_s
                              ),
                              class: "form-select" %>
                        <div class="form-text">در فیش فعلی شرط محاسباتی بر اساس pay_type وجود ندارد (فقط لیبل).</div>
                      </div>

                      <!-- Total salary -->
                      <div class="col-12 col-lg-4">
                        <label class="form-label small mb-1">حقوق کل</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][total_salary]",
                                sp.total_salary,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <!-- Hourly rate -->
                      <div class="col-12 col-lg-4">
                        <label class="form-label small mb-1">نرخ ساعتی</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][hourly_rate]",
                                sp.hourly_rate,
                                class: "form-control text-end",
                                min: 0, step: "0.01" %>
                          <span class="input-group-text">ریال</span>
                        </div>
                        <div class="form-text">اگر خالی باشد، در تایید حسابداری ۰ ذخیره/اعمال می‌شود.</div>
                      </div>

                      <div class="col-12"><hr class="my-1"></div>

                      <!-- Bases -->
                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">پایه (seniority_base)</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][seniority_base]",
                                sp.seniority_base,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">پایه سنوات ماهانه</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][monthly_seniority_base]",
                                sp.monthly_seniority_base,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <!-- Allowances -->
                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">مسکن و خواروبار</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][housing_allowance]",
                                sp.housing_allowance,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">ایاب و ذهاب</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][food_allowance]",
                                sp.food_allowance,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">تاهل</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][marriage_allowance]",
                                sp.marriage_allowance,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">فرزند</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][child_allowance]",
                                sp.child_allowance,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12"><hr class="my-1"></div>

                      <!-- Deductions -->
                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">قسط وام</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][loan_installment]",
                                sp.loan_installment,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">صندوق ۳٪</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][fund_three_percent]",
                                sp.fund_three_percent,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">صندوق ۶٪</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][fund_six_percent]",
                                sp.fund_six_percent,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <!-- ✅ NEW: Supplementary insurance (deduction) -->
                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">بیمه تکمیلی (کسورات)</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][supplementary_insurance]",
                                sp.respond_to?(:supplementary_insurance) ? sp.supplementary_insurance.to_i : 0,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                        <div class="form-text">در مرحله Accounting Confirm داخل SalaryArchive ذخیره و در پرداختی دوم کم می‌شود.</div>
                      </div>

                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
        <% end %>

      </div>

      <!-- Sticky Save Bar -->
      <div class="sp-sticky-save mt-3">
        <div class="sp-savebar d-flex flex-wrap align-items-center justify-content-between gap-2">
          <div class="small sp-muted">
            تغییرات روی <strong>SalaryProfile</strong> ذخیره می‌شود.
            برای اثر روی فیشِ ماه جاری، معمولاً بعدش باید مرحله <strong>accounting_confirm</strong> همان ماه اجرا شود.
          </div>
          <div class="d-flex gap-2">
            <%= submit_tag "ذخیره تغییرات", class: "btn btn-primary rounded-pill px-4" %>
          </div>
        </div>
      </div>

    <% end %>

    <!-- Your formula table (unchanged) -->
    <div class="mt-5 sp-table">
      <table class="table table-bordered table-striped align-middle mt-5" dir="rtl" style="width:100%; font-size:14px;">
        <thead class="table-light">
          <tr>
            <th style="width:230px;">آیتم فیش</th>
            <th style="width:360px;">فرمول دقیق (همون چیزی که الان تو کد اجرا میشه)</th>
            <th>توضیح فارسیِ واضح (منبع عدد + اینکه چه زمانی/چطور وارد آرشیو میشه)</th>
          </tr>
        </thead>
        <tbody>
          <!-- (همون جدول طولانی خودت بدون تغییر اینجا می‌مونه) -->
        </tbody>
      </table>
    </div>

  </div>
</div>