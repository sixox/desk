<!-- app/views/salary_profiles/bulk_edit.html.erb -->
<style>
  /* ============== Page-only Pro UI (Bootstrap-friendly) ============== */
  .sp-wrap { max-width: 1500px; margin: 0 auto; }
  .sp-hero{
    border-radius: 22px;
    border: 1px solid rgba(0,0,0,.06);
    background:
      radial-gradient(1200px 380px at 10% 0%, rgba(13,110,253,.10), transparent 60%),
      radial-gradient(900px 340px at 90% 10%, rgba(32,201,151,.10), transparent 55%),
      linear-gradient(180deg, rgba(0,0,0,.02), rgba(0,0,0,0));
    box-shadow: 0 14px 40px rgba(0,0,0,.06);
    overflow: hidden;
  }
  .sp-muted { color:#6c757d; }

  .sp-pill{
    display:inline-flex; align-items:center; gap:8px;
    padding: 7px 12px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(255,255,255,.9);
    font-size: .82rem;
    color:#343a40;
    white-space: nowrap;
  }

  .sp-accordion .accordion-item{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px !important;
    overflow:hidden;
    background:#fff;
    box-shadow: 0 10px 22px rgba(0,0,0,.04);
    margin-bottom: 10px;
  }
  .sp-accordion .accordion-button{
    background: linear-gradient(180deg, rgba(0,0,0,.03), rgba(0,0,0,0));
    border:0;
    box-shadow:none !important;
  }
  .sp-accordion .accordion-button:focus{ box-shadow:none !important; }
  .sp-accordion .accordion-body{ background:#fff; }

  .sp-userline .sp-name{ font-weight: 900; letter-spacing:-.2px; }
  .sp-userline .badge{ border-radius: 999px; }

  .sp-mini-badge{
    border: 1px solid rgba(0,0,0,.08);
    background: rgba(0,0,0,.02);
    color:#495057;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: .78rem;
  }

  .sp-kpi{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px;
    padding: 10px 12px;
    background:#fff;
  }
  .sp-kpi .lbl{ font-size:.78rem; color:#6c757d; }
  .sp-kpi .val{ font-size:1.05rem; font-weight:800; letter-spacing:-.2px; }

  .sp-form-card{
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 10px 22px rgba(0,0,0,.04);
    overflow:hidden;
  }
  .sp-form-card .card-header{
    background: linear-gradient(180deg, rgba(0,0,0,.03), rgba(0,0,0,0));
    border-bottom: 1px solid rgba(0,0,0,.06);
  }
  .sp-section-title{ font-weight:900; letter-spacing:-.2px; font-size:.95rem; }
  .sp-section-sub{ font-size:.82rem; color:#6c757d; }

  .sp-table{
    border-radius: 18px;
    overflow:hidden;
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 10px 22px rgba(0,0,0,.04);
  }
  .sp-table thead th{ background: rgba(0,0,0,.03) !important; }

  .sp-sticky-save{ position: sticky; bottom: 12px; z-index: 3; }
  .sp-savebar{
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.06);
    background: rgba(255,255,255,.92);
    box-shadow: 0 14px 30px rgba(0,0,0,.08);
    backdrop-filter: blur(8px);
    padding: 10px 12px;
  }

  /* nicer inputs */
  .form-control, .form-select, .input-group-text{ border-radius: 12px; }
  .input-group .form-control{ border-top-right-radius:0; border-bottom-right-radius:0; }
  .input-group .input-group-text{ border-top-left-radius:0; border-bottom-left-radius:0; }
</style>

<div class="container-fluid py-4 text-end" dir="rtl">
  <div class="sp-wrap">

    <!-- Hero -->
    <div class="sp-hero p-4 p-lg-5 mb-4">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
        <div>
          <h4 class="mb-1 fw-bold">ویرایش گروهی پروفایل حقوق</h4>
          <div class="sp-muted small">
            فقط کاربران دارای <strong>SalaryProfile</strong> نمایش داده می‌شوند.
            تغییرات این صفحه روی «مبنای حقوق» ذخیره می‌شود (SalaryProfile).
          </div>

          <div class="mt-3 d-flex flex-wrap gap-2">
            <span class="sp-pill">🧾 تعداد کاربران: <strong><%= @users.size %></strong></span>
            <span class="sp-pill">🛠️ نقش شما: <strong><%= current_user.role %></strong></span>
            <span class="sp-pill">👤 مدیر: <strong><%= current_user.is_manager ? "بله" : "خیر" %></strong></span>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <%= link_to "بازگشت", :back, class: "btn btn-outline-secondary rounded-pill px-3" rescue nil %>
          <a class="btn btn-outline-dark rounded-pill px-3" href="javascript:window.location.reload()">تازه‌سازی</a>
        </div>
      </div>
    </div>

    <%= form_with url: bulk_update_salary_profiles_path, method: :patch do %>

      <!-- Top Save -->
      <div class="d-flex flex-wrap gap-2 justify-content-end mb-3">
        <%= submit_tag "ذخیره تغییرات", class: "btn btn-primary rounded-pill px-4" %>
      </div>

      <div class="accordion sp-accordion" id="salaryProfilesAcc">

        <% @users.each do |user| %>
          <% sp = user.salary_profile %>
          <% next unless sp %>

          <% pay_label =
              {
                "hourly" => "ساعتی (محاسبه کامل)",
                "fixed" => "ثابت",
                "fixed_with_overtime" => "ثابت + اضافه/کسری"
              }[sp.pay_type.to_s] || "نامشخص"
          %>

          <% total_salary = sp.total_salary.to_i %>

          <div class="accordion-item">
            <h2 class="accordion-header" id="hdr_<%= user.id %>">
              <button class="accordion-button collapsed py-3" type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#col_<%= user.id %>"
                      aria-expanded="false"
                      aria-controls="col_<%= user.id %>">

                <div class="d-flex w-100 align-items-center justify-content-between gap-3">
                  <div class="d-flex flex-column sp-userline">

                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <span class="sp-name"><%= user.name.presence || "کاربر ##{user.id}" %></span>
                      <span class="badge text-bg-light border">ID: <%= user.id %></span>
                      <span class="badge text-bg-primary"><%= pay_label %></span>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-2">
                      <span class="sp-mini-badge">حقوق کل: <strong><%= number_with_delimiter(total_salary) %></strong></span>
                      <span class="sp-mini-badge">نرخ ساعتی: <strong><%= sp.hourly_rate.present? ? number_with_delimiter(sp.hourly_rate) : "—" %></strong></span>
                      <span class="sp-mini-badge">پایه: <strong><%= number_with_delimiter(sp.seniority_base.to_i) %></strong></span>
                      <span class="sp-mini-badge">سنوات: <strong><%= number_with_delimiter(sp.monthly_seniority_base.to_i) %></strong></span>
                    </div>

                  </div>

                  <div class="d-none d-md-block">
                    <span class="badge text-bg-secondary">برای ویرایش باز کنید</span>
                  </div>
                </div>

              </button>
            </h2>

            <div id="col_<%= user.id %>" class="accordion-collapse collapse"
                 aria-labelledby="hdr_<%= user.id %>"
                 data-bs-parent="#salaryProfilesAcc">

              <div class="accordion-body p-3 p-lg-4">

                <!-- KPIs -->
                <div class="row g-2 mb-3">
                  <div class="col-12 col-md-4">
                    <div class="sp-kpi">
                      <div class="lbl">حقوق کل</div>
                      <div class="val"><%= number_with_delimiter(sp.total_salary.to_i) %></div>
                    </div>
                  </div>
                  <div class="col-12 col-md-4">
                    <div class="sp-kpi">
                      <div class="lbl">نرخ ساعتی</div>
                      <div class="val"><%= sp.hourly_rate.present? ? number_with_delimiter(sp.hourly_rate) : "—" %></div>
                    </div>
                  </div>
                  <div class="col-12 col-md-4">
                    <div class="sp-kpi">
                      <div class="lbl">جمع مزایا (مسکن + بن + تاهل + فرزند)</div>
                      <div class="val">
                        <%= number_with_delimiter(
                              sp.housing_allowance.to_i + sp.food_allowance.to_i + sp.marriage_allowance.to_i + sp.child_allowance.to_i
                            ) %>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="card sp-form-card">
                  <div class="card-header p-3">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                      <div>
                        <div class="sp-section-title">تنظیمات پروفایل حقوق</div>
                        <div class="sp-section-sub">
                          این مقادیر «مبنای آرشیو ماه» هستند. (فیش از SalaryArchive می‌خونه؛
                          اعداد آرشیو در مرحله accounting_confirm ذخیره میشن.)
                        </div>
                      </div>
                      <span class="sp-pill">🧩 SalaryProfile ID: <strong><%= sp.id %></strong></span>
                    </div>
                  </div>

                  <div class="card-body p-3 p-lg-4">
                    <div class="row g-3">

                      <!-- Pay type -->
                      <div class="col-12 col-lg-4">
                        <label class="form-label small mb-1">نوع پرداخت</label>
                        <%= select_tag "salary_profiles[#{sp.id}][pay_type]",
                              options_for_select(
                                [
                                  ["ساعتی (محاسبه کامل)", "hourly"],
                                  ["ثابت", "fixed"],
                                  ["ثابت + اضافه/کسری", "fixed_with_overtime"]
                                ],
                                sp.pay_type.to_s
                              ),
                              class: "form-select" %>
                        <div class="form-text">در فیش فعلی شرط محاسباتی بر اساس pay_type وجود ندارد (فقط لیبل).</div>
                      </div>

                      <!-- Total salary -->
                      <div class="col-12 col-lg-4">
                        <label class="form-label small mb-1">حقوق کل</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][total_salary]",
                                sp.total_salary,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <!-- Hourly rate -->
                      <div class="col-12 col-lg-4">
                        <label class="form-label small mb-1">نرخ ساعتی</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][hourly_rate]",
                                sp.hourly_rate,
                                class: "form-control text-end",
                                min: 0, step: "0.01" %>
                          <span class="input-group-text">ریال</span>
                        </div>
                        <div class="form-text">اگر خالی باشد، در تایید حسابداری ۰ ذخیره/اعمال می‌شود.</div>
                      </div>

                      <div class="col-12"><hr class="my-1"></div>

                      <!-- Bases -->
                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">پایه (seniority_base)</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][seniority_base]",
                                sp.seniority_base,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">پایه سنوات ماهانه</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][monthly_seniority_base]",
                                sp.monthly_seniority_base,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <!-- Allowances -->
                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">مسکن</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][housing_allowance]",
                                sp.housing_allowance,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">بن</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][food_allowance]",
                                sp.food_allowance,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">تاهل</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][marriage_allowance]",
                                sp.marriage_allowance,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">فرزند</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][child_allowance]",
                                sp.child_allowance,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12"><hr class="my-1"></div>

                      <!-- Deductions -->
                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">قسط وام</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][loan_installment]",
                                sp.loan_installment,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">صندوق ۳٪</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][fund_three_percent]",
                                sp.fund_three_percent,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                      <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small mb-1">صندوق ۶٪</label>
                        <div class="input-group">
                          <%= number_field_tag "salary_profiles[#{sp.id}][fund_six_percent]",
                                sp.fund_six_percent,
                                class: "form-control text-end",
                                min: 0, step: 1 %>
                          <span class="input-group-text">ریال</span>
                        </div>
                      </div>

                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
        <% end %>

      </div>

      <!-- Sticky Save Bar -->
      <div class="sp-sticky-save mt-3">
        <div class="sp-savebar d-flex flex-wrap align-items-center justify-content-between gap-2">
          <div class="small sp-muted">
            تغییرات روی <strong>SalaryProfile</strong> ذخیره می‌شود.
            برای اثر روی فیشِ ماه جاری، معمولاً بعدش باید مرحله <strong>accounting_confirm</strong> همان ماه اجرا شود.
          </div>
          <div class="d-flex gap-2">
            <%= submit_tag "ذخیره تغییرات", class: "btn btn-primary rounded-pill px-4" %>
          </div>
        </div>
      </div>

    <% end %>

    <!-- Your formula table: just wrap for nicer look -->
    <div class="mt-5 sp-table">
<table class="table table-bordered table-striped align-middle mt-5" dir="rtl" style="width:100%; font-size:14px;">
  <thead class="table-light">
    <tr>
      <th style="width:230px;">آیتم فیش</th>
      <th style="width:360px;">فرمول دقیق (همون چیزی که الان تو کد اجرا میشه)</th>
      <th>توضیح فارسیِ واضح (منبع عدد + اینکه چه زمانی/چطور وارد آرشیو میشه)</th>
    </tr>
  </thead>

  <tbody>

    <!-- ========= پایه های زمانی ========= -->
    <tr class="table-secondary">
      <td colspan="3"><strong>۱) پایه‌های زمانی و تعدیل ماه</strong></td>
    </tr>

    <tr>
      <td><strong>تعداد روزهای ماه</strong> (month_days)</td>
      <td>
        month_days = (shamsi_month.end_at.to_date - shamsi_month.start_at.to_date).to_i + 1
      </td>
      <td>
        این عدد از خود <strong>ShamsiMonth</strong> میاد (start_at / end_at).
        بعداً برای این استفاده میشه که بعضی مبلغ‌های «ماهانهِ مبنا-۳۰روز» رو به تعداد روز واقعی ماه تبدیل کنیم.
      </td>
    </tr>

    <tr>
      <td><strong>تعدیل مبلغ ماهانه ۳۰روزه به ماه واقعی</strong> (adjust_30_to_month)</td>
      <td>
        adjust_30_to_month(x) = ((x.to_f / 30.0) * month_days).round
      </td>
      <td>
        یعنی: «اگر یک مبلغ برای ۳۰ روز تعریف شده»، اون رو نسبت به تعداد روز واقعی ماه (۲۹/۳۰/۳۱) تعدیل می‌کنیم.
        طبق کد payslip، <strong>فقط برای total_salary</strong> استفاده شده (نه برای همه آیتم‌ها).
      </td>
    </tr>

    <tr>
      <td><strong>تبدیل دقیقه به ساعت برای نمایش</strong> (hours)</td>
      <td>
        hours(mins) = ((mins.to_i) / 60.0).round(2)
      </td>
      <td>
        هرجا تو آرشیو دقیقه داریم (مثل total_work_minutes, overtime_minutes, deficit_minutes)
        این فرمول فقط برای نمایش به ساعت استفاده میشه.
      </td>
    </tr>

    <!-- ========= آیتم های ورودی از SalaryArchive ========= -->
    <tr class="table-secondary">
      <td colspan="3"><strong>۲) ورودی‌های اصلی که در فیش استفاده میشن (همه از SalaryArchive خوانده میشن)</strong></td>
    </tr>

    <tr>
      <td><strong>حقوق پایه</strong> (base_salary)</td>
      <td>
        base_salary = archive.seniority_base.to_i
      </td>
      <td>
        این عدد <strong>مستقیماً از SalaryArchive</strong> خونده میشه.
        اما منطق اینکه چطور داخل آرشیو قرار می‌گیره اینه:
        در اکشن <strong>accounting_confirm_all</strong> مقدارش از <strong>SalaryProfile.seniority_base</strong> گرفته میشه،
        بعد با فرمول تعدیل ۳۰→ماه (adjust_by_month_days) تعدیل میشه و داخل آرشیو ذخیره میشه.
      </td>
    </tr>

    <tr>
      <td><strong>پایه سنوات ماهانه</strong> (paye_sanavat)</td>
      <td>
        paye_sanavat = archive.monthly_seniority_base.to_i
      </td>
      <td>
        این هم <strong>از SalaryArchive</strong> خونده میشه.
        ولی مقدارش هنگام <strong>accounting_confirm_all</strong> از <strong>SalaryProfile.monthly_seniority_base</strong>
        گرفته میشه، تعدیل ۳۰→ماه میشه، بعد داخل آرشیو ذخیره میشه.
      </td>
    </tr>

    <tr>
      <td><strong>حق مسکن</strong> (housing)</td>
      <td>
        housing = archive.housing_allowance.to_i
      </td>
      <td>
        در <strong>accounting_confirm_all</strong> مقدارش از <strong>SalaryProfile.housing_allowance</strong> گرفته میشه
        و <strong>بدون هیچ تعدیلی</strong> همان عدد داخل آرشیو ذخیره میشه.
      </td>
    </tr>

    <tr>
      <td><strong>خواربار</strong> (food)</td>
      <td>
        food = archive.food_allowance.to_i
      </td>
      <td>
        از <strong>SalaryProfile.food_allowance</strong> گرفته میشه و در <strong>accounting_confirm_all</strong>
        <strong>بدون تغییر</strong> داخل آرشیو ذخیره میشه.
      </td>
    </tr>

    <tr>
      <td><strong>حق تأهل</strong> (marriage)</td>
      <td>
        marriage = archive.marriage_allowance.to_i
      </td>
      <td>
        از <strong>SalaryProfile.marriage_allowance</strong> گرفته میشه و در <strong>accounting_confirm_all</strong>
        <strong>بدون تغییر</strong> داخل آرشیو ذخیره میشه.
      </td>
    </tr>

    <tr>
      <td><strong>حق اولاد</strong> (child)</td>
      <td>
        child = archive.child_allowance.to_i
      </td>
      <td>
        از <strong>SalaryProfile.child_allowance</strong> گرفته میشه و در <strong>accounting_confirm_all</strong>
        <strong>بدون تغییر</strong> داخل آرشیو ذخیره میشه.
      </td>
    </tr>

    <tr>
      <td><strong>حقوق کل/مصوب</strong> (total_salary - خام)</td>
      <td>
        total_salary_raw = archive.total_salary.to_i
      </td>
      <td>
        این عدد در <strong>accounting_confirm_all</strong> از <strong>SalaryProfile.total_salary</strong> گرفته میشه
        و همان مقدار داخل آرشیو ذخیره میشه.  
        بعداً در خود فیش، برای ماه‌های ۲۹/۳۰/۳۱ روزه <strong>تعدیل میشه</strong> (ردیف بعد).
      </td>
    </tr>

    <tr>
      <td><strong>نرخ ساعتی</strong> (hourly_rate)</td>
      <td>
        hourly_rate = archive.hourly_rate.present? ? archive.hourly_rate.to_f : 0.0
      </td>
      <td>
        این نرخ در <strong>accounting_confirm_all</strong> از <strong>SalaryProfile.hourly_rate</strong> برداشته میشه.
        اگر در پروفایل مقدار نداشته باشه، طبق کد فعلی <strong>۰</strong> ذخیره/خوانده میشه.  
        ✅ نکته مهم: در کد فعلی <strong>هیچ فرمولی برای استخراج نرخ ساعتی از total_salary</strong> وجود ندارد.
        یعنی «اگر hourly_rate خالی باشد»، فیش اضافه‌کاری و کسری عملاً صفر اثر می‌گذارند (چون ضرب در ۰ می‌شوند).
      </td>
    </tr>

    <tr>
      <td><strong>قسط وام</strong> (loan)</td>
      <td>
        loan = archive.loan_installment.to_i
      </td>
      <td>
        در <strong>accounting_confirm_all</strong> مقدارش از <strong>SalaryProfile.loan_installment</strong> خوانده میشه
        و <strong>بدون تغییر</strong> داخل آرشیو ذخیره میشه.
        بعد در پرداختی دوم به صورت کاهشی کم میشه.
      </td>
    </tr>

    <tr>
      <td><strong>ذخیره ۳٪</strong> (fund3)</td>
      <td>
        fund3 = archive.fund_three_percent.to_i
      </td>
      <td>
        این عدد از <strong>SalaryProfile.fund_three_percent</strong> خوانده میشه و در <strong>accounting_confirm_all</strong>
        <strong>بدون تغییر</strong> وارد آرشیو میشه.  
        بعداً در پرداختی دوم از حقوق کم می‌شود.
      </td>
    </tr>

    <tr>
      <td><strong>ذخیره ۶٪</strong> (fund6)</td>
      <td>
        fund6 = archive.fund_six_percent.to_i
      </td>
      <td>
        این عدد از <strong>SalaryProfile.fund_six_percent</strong> خوانده میشه و در <strong>accounting_confirm_all</strong>
        <strong>بدون تغییر</strong> وارد آرشیو میشه.  
        بعداً در پرداختی دوم از حقوق کم می‌شود.
      </td>
    </tr>

    <!-- ========= محاسبات قانونی (پرداختی اول) ========= -->
    <tr class="table-secondary">
      <td colspan="3"><strong>۳) محاسبات قانونی و پرداختی اول</strong></td>
    </tr>

    <tr>
      <td><strong>حقوق قانونی</strong> (legal_salary)</td>
      <td>
        legal_salary = base_salary + marriage + housing + food + paye_sanavat
      </td>
      <td>
        یعنی جمعِ: حقوق پایه + حق تأهل + حق مسکن + خواربار + پایه سنوات.  
        همه این‌ها <strong>از SalaryArchive</strong> می‌آیند (که قبلاً از SalaryProfile پر شده‌اند).
      </td>
    </tr>

    <tr>
      <td><strong>مبنای بیمه</strong> (insurance_base_sum)</td>
      <td>
        insurance_base_sum = seniority_base_adj + marriage_allowance + housing_allowance + food_allowance + monthly_seniority_adj
      </td>
      <td>
        این محاسبه در <strong>accounting_confirm_all</strong> انجام میشه (نه در partial فیش).  
        نکته: طبق کد، <strong>child_allowance (حق اولاد) داخل مبنای بیمه لحاظ نشده</strong>.
      </td>
    </tr>

    <tr>
      <td><strong>بیمه (۷٪)</strong> (insurance)</td>
      <td>
        insurance = (insurance_base_sum.to_f * 0.07).round
      </td>
      <td>
        بیمه در <strong>accounting_confirm_all</strong> محاسبه و داخل <strong>SalaryArchive.insurance</strong> ذخیره میشه،
        بعد در فیش فقط همان مقدار نمایش داده میشه.
      </td>
    </tr>

    <tr>
      <td><strong>پرداختی اول</strong> (payment_1)</td>
      <td>
        payment_1 = legal_salary - insurance
      </td>
      <td>
        پرداختی اول = حقوق قانونی − بیمه.  
        یعنی «بخش قانونی پرداخت» که مستقیم از فرمول‌های بالا میاد.
      </td>
    </tr>

    <!-- ========= کارکرد / تعدیلات (پرداختی دوم) ========= -->
    <tr class="table-secondary">
      <td colspan="3"><strong>۴) کارکرد، اضافه‌کاری/کسری و پرداختی دوم</strong></td>
    </tr>

    <tr>
      <td><strong>حقوق مصوب تعدیل‌شده</strong> (total_salary_adj)</td>
      <td>
        total_salary_adj = ((archive.total_salary.to_f / 30.0) * month_days).round
      </td>
      <td>
        اول total_salary از <strong>SalaryArchive</strong> خوانده میشه (که از پروفایل آمده).  
        بعد این فرمول آن را از مبنای ۳۰ روز به تعداد روز واقعی ماه تبدیل می‌کند.
      </td>
    </tr>

    <tr>
      <td><strong>کسریِ موثر در فیش</strong> (deficit_mins → deficit_h)</td>
      <td>
        deficit_mins = (archive.manual_deficit_minutes != 0) ? archive.manual_deficit_minutes : archive.deficit_minutes
        <br/>
        deficit_h = (deficit_mins / 60.0).round(2)
      </td>
      <td>
        اگر HR/مدیر یک مقدار دستی وارد کند (manual_deficit_minutes != 0)، همان مقدار دستی مبنای فیش می‌شود؛
        وگرنه از کسری سیستمی (deficit_minutes) استفاده می‌کند.
      </td>
    </tr>

    <tr>
      <td><strong>اضافه‌کاریِ موثر در فیش</strong> (overtime_mins → overtime_h)</td>
      <td>
        overtime_mins = (archive.manual_overtime_minutes != 0) ? archive.manual_overtime_minutes : archive.overtime_minutes
        <br/>
        overtime_h = (overtime_mins / 60.0).round(2)
      </td>
      <td>
        دقیقاً مشابه کسری: اگر مقدار دستی وجود داشته باشد، همان مبنا است؛
        وگرنه اضافه‌کاری سیستمی استفاده می‌شود.
      </td>
    </tr>

    <tr>
      <td><strong>کسر کسری</strong> (deficit_deduction)</td>
      <td>
        deficit_deduction = (deficit_h * hourly_rate)
      </td>
      <td>
        مبلغ کسری = «ساعت کسری × نرخ ساعتی».  
        نرخ ساعتی از آرشیو می‌آید (که از SalaryProfile آمده).  
        اگر hourly_rate صفر/خالی باشد → این کسر هم صفر می‌شود.
      </td>
    </tr>

    <tr>
      <td><strong>پرداخت اضافه‌کاری</strong> (overtime_pay)</td>
      <td>
        overtime_pay = (overtime_h * hourly_rate * 1.4)
      </td>
      <td>
        مبلغ اضافه‌کاری = «ساعت اضافه‌کاری × نرخ ساعتی × ۱.۴».  
        ضریب ۱.۴ ثابت است و دقیقاً طبق کد اعمال می‌شود.
      </td>
    </tr>

    <tr>
      <td><strong>پرداختی دوم</strong> (payment_2)</td>
      <td>
        payment_2 = (total_salary_adj - fund6 - fund3 - loan - deficit_deduction + overtime_pay).round
      </td>
      <td>
        پرداختی دوم از «حقوق مصوب تعدیل‌شده» شروع می‌شود، سپس:  
        - ذخیره ۶٪ کم می‌شود  
        - ذخیره ۳٪ کم می‌شود  
        - قسط وام کم می‌شود  
        - مبلغ کسری کم می‌شود  
        - مبلغ اضافه‌کاری اضافه می‌شود  
        و در آخر round می‌شود.
      </td>
    </tr>

    <!-- ========= رابطه SalaryProfile و SalaryArchive و PaySlip ========= -->
    <tr class="table-secondary">
      <td colspan="3"><strong>۵) رابطه داده‌ها (طبق چیزی که در کد شما انجام می‌شود)</strong></td>
    </tr>

    <tr>
      <td><strong>SalaryProfile</strong> (پروفایل حقوق)</td>
      <td>
        منبع اعداد اولیه (total_salary, hourly_rate, allowances, funds, loan, ...)
      </td>
      <td>
        پروفایل «تعریف مبنا» است.  
        در زمان <strong>accounting_confirm_all</strong>، برای هر کاربر پروفایل خوانده می‌شود و مقادیر لازم
        داخل <strong>SalaryArchive</strong> ذخیره می‌گردد (یعنی آرشیو snapshot همان ماه است).
      </td>
    </tr>

    <tr>
      <td><strong>SalaryArchive</strong> (آرشیو ماه)</td>
      <td>
        خروجی تایید حسابداری + جمع دقیقه‌های کارکرد/اضافه‌کاری/کسری + مبالغ ذخیره‌شده
      </td>
      <td>
        آرشیو همان چیزی است که فیش از آن ساخته می‌شود.  
        بعد از manager/hr/accounting confirm، فیلدهای مالی (پایه/سنوات/بیمه/...) در آرشیو «نهایی» می‌شود.
      </td>
    </tr>

    <tr>
      <td><strong>فیش حقوقی (PaySlip view)</strong></td>
      <td>
        فقط محاسبات نمایشی روی داده‌های SalaryArchive
      </td>
      <td>
        partial فیش شما <strong>هیچ عددی را از SalaryProfile مستقیم نمی‌خواند</strong>؛
        همه چیز را از <strong>SalaryArchive</strong> می‌گیرد و همان فرمول‌هایی که بالا نوشته شد را روی آن اجرا می‌کند.
      </td>
    </tr>

    <!-- ========= انواع pay_type ========= -->
    <tr class="table-secondary">
      <td colspan="3"><strong>۶) تفاوت نوع پرداخت (pay_type) در همین فیش</strong></td>
    </tr>

    <tr>
      <td><strong>fixed</strong></td>
      <td>در فرمول فیش هیچ if/else روی pay_type وجود ندارد.</td>
      <td>
        طبق کدی که فرستادی، pay_type فقط برای «label در جدول‌ها» استفاده شده و
        <strong>هیچ تفاوتی در محاسبات payslip ایجاد نمی‌کند</strong>.  
        یعنی اگر کاربر fixed باشد هم همین فرمول‌های payment_1 و payment_2 اجرا می‌شوند.
      </td>
    </tr>

    <tr>
      <td><strong>hourly</strong></td>
      <td>در فرمول فیش هیچ if/else روی pay_type وجود ندارد.</td>
      <td>
        با کد فعلی، تفاوت محاسباتی ندارد.  
        تنها چیزی که واقعاً اثر دارد: <strong>hourly_rate</strong> و دقیقه‌های overtime/deficit.
      </td>
    </tr>

    <tr>
      <td><strong>fixed_with_overtime</strong></td>
      <td>در فرمول فیش هیچ if/else روی pay_type وجود ندارد.</td>
      <td>
        طبق کد موجود، این هم مثل بقیه محاسبه می‌شود.  
        اگر انتظار داری رفتار متفاوت باشد (مثلاً فقط اضافه‌کاری روی بخشی اثر بگذارد)،
        در کد payslip هنوز پیاده‌سازی نشده.
      </td>
    </tr>

  </tbody>
</table>
